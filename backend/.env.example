# =============================================================================
# backend/.env.example
# Backend environment variables configuration template
# =============================================================================

# Server settings
FLASK_ENV=development
PORT=5000
SECRET_KEY=dev-session-key-active-recall-generations
UPLOAD_FOLDER=uploads

# Database configuration (PostgreSQL for AWS RDS, SQLite default)
# Example PostgreSQL: postgresql://db_user:db_password@rds-instance-endpoint:5432/dbname
DATABASE_URL=sqlite:///app.db

# Storage Provider configuration ('local' or 's3')
STORAGE_PROVIDER=local

# AWS S3 Cloud Storage credentials (Required if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET=your_s3_bucket_name

# Authentication Provider configuration ('firebase' or 'cognito')
AUTH_PROVIDER=firebase

# Firebase Admin SDK settings (Required if AUTH_PROVIDER=firebase)
# Path to your downloaded service account key JSON file
FIREBASE_SERVICE_ACCOUNT_KEY=config/firebase-service-account-key.json

# AWS Cognito User Pool settings (Required if AUTH_PROVIDER=cognito)
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1
