# =============================================================================
# frontend/.env.example
# Frontend environment variables configuration template
# =============================================================================

# Central Backend Endpoint URL
VITE_API_URL=http://localhost:5000

# Authentication Configuration ('firebase' or 'cognito')
VITE_AUTH_PROVIDER=firebase

# Database Engine persistence configuration ('firebase' or 'postgres')
# - 'firebase': Saves historical user summaries directly to Firestore
# - 'postgres': Sends REST sync calls to Flask SQLAlchemy backend history APIs
VITE_DB_TYPE=firebase

# Firebase Config Keys (Required if VITE_AUTH_PROVIDER=firebase or VITE_DB_TYPE=firebase)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=1:your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-xxxxxxxxxx

# AWS Cognito / Amplify Configurations (Required if VITE_AUTH_PROVIDER=cognito)
VITE_AWS_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_AWS_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_AWS_REGION=us-east-1